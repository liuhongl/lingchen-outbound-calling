<?xml version="1.0" encoding="utf-8"?>
<include>
  <context name="sip_provider_sandbox">
    <extension name="sip-provider-sandbox-forbidden-caller">
      <condition field="caller_id_number" expression="^(?!037123124845$).+">
        <action application="respond" data="403"/>
        <action application="hangup" data="CALL_REJECTED"/>
      </condition>
    </extension>

    <extension name="sip-provider-sandbox-invalid-number-plus86">
      <condition field="destination_number" expression="^\+86\d+$">
        <action application="respond" data="484"/>
        <action application="hangup" data="UNALLOCATED_NUMBER"/>
      </condition>
    </extension>

    <extension name="sip-provider-sandbox-invalid-number-86">
      <condition field="destination_number" expression="^86\d{11}$">
        <action application="respond" data="484"/>
        <action application="hangup" data="UNALLOCATED_NUMBER"/>
      </condition>
    </extension>

    <extension name="sip-provider-sandbox-invalid-number-short">
      <condition field="destination_number" expression="^1000$">
        <action application="respond" data="404"/>
        <action application="hangup" data="UNALLOCATED_NUMBER"/>
      </condition>
    </extension>

    <extension name="sip-provider-sandbox-timeout">
      <condition field="destination_number" expression="^19900000000$">
        <action application="pre_answer"/>
        <action application="sleep" data="1500"/>
        <action application="respond" data="408"/>
        <action application="hangup" data="NO_ANSWER"/>
      </condition>
    </extension>

    <extension name="sip-provider-sandbox-busy">
      <condition field="destination_number" expression="^19900000001$">
        <action application="respond" data="486"/>
        <action application="hangup" data="USER_BUSY"/>
      </condition>
    </extension>

    <extension name="sip-provider-sandbox-decline">
      <condition field="destination_number" expression="^19900000002$">
        <action application="respond" data="603"/>
        <action application="hangup" data="CALL_REJECTED"/>
      </condition>
    </extension>

    <extension name="sip-provider-sandbox-upstream-508">
      <condition field="destination_number" expression="^19900000003$">
        <action application="respond" data="508"/>
        <action application="hangup" data="NORMAL_UNSPECIFIED"/>
      </condition>
    </extension>

    <extension name="sip-provider-sandbox-trunk-unavailable">
      <condition field="destination_number" expression="^19900000004$">
        <action application="respond" data="503"/>
        <action application="hangup" data="NORMAL_TEMPORARY_FAILURE"/>
      </condition>
    </extension>

    <extension name="sip-provider-sandbox-progress-then-answer">
      <condition field="destination_number" expression="^18518968743$">
        <action application="pre_answer"/>
        <action application="sleep" data="800"/>
        <action application="answer"/>
        <action application="set" data="playback_terminators=none"/>
        <action application="park"/>
      </condition>
    </extension>

    <extension name="sip-provider-sandbox-answer">
      <condition field="destination_number" expression="^(15800967789|\d{11}|037123124845)$">
        <action application="ring_ready"/>
        <action application="sleep" data="500"/>
        <action application="answer"/>
        <action application="set" data="playback_terminators=none"/>
        <action application="park"/>
      </condition>
    </extension>

    <extension name="sip-provider-sandbox-invalid-fallback">
      <condition field="destination_number" expression="^.*$">
        <action application="respond" data="484"/>
        <action application="hangup" data="UNALLOCATED_NUMBER"/>
      </condition>
    </extension>
  </context>
</include>
