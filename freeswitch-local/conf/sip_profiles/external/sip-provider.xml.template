<include>
  <!--
    Real sip-provider trunk template.

    This file is intentionally named *.template so local FreeSWITCH will not
    load it through external/*.xml. To enable on a public SIP/RTP reachable
    server, copy it to sip-provider.xml after confirming vars.xml external_sip_ip
    and external_rtp_ip point to the server public address.
  -->
  <gateway name="sip-provider">
    <param name="username" value="037123124845"/>
    <param name="extension" value="037123124845"/>
    <param name="proxy" value="47.94.86.132:5089"/>
    <param name="realm" value="47.94.86.132"/>
    <param name="from-user" value="037123124845"/>
    <param name="from-domain" value="47.94.86.132"/>
    <param name="password" value=""/>
    <param name="register" value="false"/>
    <param name="register-transport" value="udp"/>
    <param name="caller-id-in-from" value="true"/>
    <param name="retry-seconds" value="30"/>
    <param name="codec-prefs" value="PCMA"/>
  </gateway>
</include>
