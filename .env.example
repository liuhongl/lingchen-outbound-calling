# Copy this file to .env for local development.
# Do not commit .env because it contains provider credentials and SIP secrets.

# Required for Doubao S2S realtime dialogue.
DOUBAO_S2S_APP_ID=
DOUBAO_S2S_ACCESS_TOKEN=

# Optional Doubao S2S settings. Keep DOUBAO_S2S_APP_KEY empty unless the
# provider explicitly gives a realtime App-Key different from the code default.
DOUBAO_S2S_APP_KEY=
DOUBAO_S2S_RESOURCE_ID=volc.speech.dialog
DOUBAO_S2S_WS_URL=wss://openspeech.bytedance.com/api/v3/realtime/dialogue
DOUBAO_S2S_SPEAKER=zh_female_vv_jupiter_bigtts
DOUBAO_S2S_OUTPUT_SAMPLE_RATE=24000

# Local server defaults.
GATEWAY_MEDIA_MODE=realtime
GATEWAY_HOST=127.0.0.1
GATEWAY_PORT=9100
LOG_LEVEL=INFO

# FreeSWITCH Event Socket, required for playback break and queue completion.
FREESWITCH_ESL_ENABLED=true
FREESWITCH_ESL_HOST=127.0.0.1
FREESWITCH_ESL_PORT=18021
FREESWITCH_ESL_PASSWORD=ClueCon
FREESWITCH_ESL_PASSWORD_ENV=FREESWITCH_ESL_PASSWORD

# Outbound call control. Local MicroSIP tests resolve registered extension
# 1000 with sofia_contact:*/{destination}. Real SIP trunk deployments change this
# to sofia/gateway/<trunk-name>/{destination}.
OUTBOUND_CALLS_ENABLED=true
OUTBOUND_ENDPOINT_TEMPLATE=sofia_contact:*/{destination}
OUTBOUND_DIALPLAN_EXTENSION=9199
OUTBOUND_DIALPLAN_CONTEXT=default
OUTBOUND_CALLER_ID_NAME=AI_Assistant
OUTBOUND_CALLER_ID_NUMBER=9000
OUTBOUND_ORIGINATE_TIMEOUT_SECONDS=30
OUTBOUND_MAX_RECENT_CALLS=200

# Phone media contract. The current commercial target is PCMA / 8k / 20ms.
PHONE_CODEC=PCMA
FREESWITCH_SAMPLE_RATE=8000
FREESWITCH_CHANNELS=1
FREESWITCH_FRAME_DURATION_MS=20
FREESWITCH_ECHO_MODE=raw

# Temporary human handoff recordings. Keep disabled unless bridge recording or
# post-call human transcript processing is being verified.
RECORDING_ENABLED=false
RECORDING_DIR=/tmp/recov_ten_handoff_recordings

# Full-call mixed recording. This is the long-term call evidence recording path
# inside the FreeSWITCH container; mount it to the host before enabling.
CALL_RECORDING_ENABLED=false
CALL_RECORDING_DIR=/var/lib/freeswitch/recordings
CALL_RECORDING_UPLOAD_ENABLED=false
CALL_RECORDING_HOST_DIR=./freeswitch-local/recordings
CALL_RECORDING_OBJECT_PREFIX=recordings
CALL_RECORDING_UPLOAD_TIMEOUT_SECONDS=30

# Server-side VAD and playback tuning.
SERVER_VAD_TYPE=server_vad
SERVER_VAD_THRESHOLD=0.5
SERVER_VAD_PREFIX_PADDING_MS=300
SERVER_VAD_SILENCE_DURATION_MS=800
SERVER_VAD_CREATE_RESPONSE=true
SERVER_VAD_INTERRUPT_RESPONSE=true
PLAYBACK_JITTER_BUFFER_MS=500
PLAYBACK_SEND_INTERVAL_MS=10
PLAYOUT_TAIL_SILENCE_MS=300

# Optional PostgreSQL connectivity. Query and insert wiring is intentionally
# disabled until the business-owned table schema is provided.
POSTGRES_ENABLED=false
POSTGRES_DSN=postgresql://postgres:postgres@127.0.0.1:5432/sip_gateway
POSTGRES_DSN_ENV=POSTGRES_DSN
POSTGRES_MIN_POOL_SIZE=1
POSTGRES_MAX_POOL_SIZE=5
POSTGRES_COMMAND_TIMEOUT_SECONDS=5

# Optional human handoff transcript processor. The HTTP JSON endpoint receives
# recording paths and must return {"turns": [...]}.
HUMAN_TRANSCRIPT_ENABLED=false
HUMAN_TRANSCRIPT_PROVIDER=http_json
HUMAN_TRANSCRIPT_HTTP_URL=
HUMAN_TRANSCRIPT_TIMEOUT_SECONDS=30

# LiveKit Web debug entry. Use a wss:// URL for LiveKit Cloud or public HTTPS
# deployments. The secret value must be stored in LIVEKIT_API_SECRET, not in
# LIVEKIT_API_SECRET_ENV.
LIVEKIT_ENABLED=false
LIVEKIT_URL=ws://127.0.0.1:7880
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_API_KEY_ENV=LIVEKIT_API_KEY
LIVEKIT_API_SECRET_ENV=LIVEKIT_API_SECRET
LIVEKIT_WEB_DEBUG_ROOM_PREFIX=web-debug
LIVEKIT_WEB_DEBUG_TOKEN_TTL_SECONDS=1800
LIVEKIT_SIP_OUTBOUND_REAL_CALLS_ENABLED=false
LIVEKIT_SIP_OUTBOUND_TRUNK_ID=
LIVEKIT_SIP_OUTBOUND_CALLER_ID=037123124845
LIVEKIT_SIP_OUTBOUND_ROOM_PREFIX=sip-outbound

# Aliyun NLS realtime ASR for LiveKit Agent Worker.
ALIYUN_NLS_APPKEY=
ALIYUN_NLS_TOKEN=
ALIYUN_NLS_URL=wss://nls-gateway-cn-shanghai.aliyuncs.com/ws/v1

# OpenAI-compatible LLM for LiveKit Agent Worker. DashScope can reuse
# DASHSCOPE_API_KEY for both LLM and CosyVoice TTS.
DASHSCOPE_API_KEY=
LLM_API_KEY=
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-plus

# Aliyun Bailian CosyVoice realtime TTS for LiveKit Agent Worker.
ALIYUN_TTS_API_KEY=
ALIYUN_TTS_WS_URL=wss://dashscope.aliyuncs.com/api-ws/v1/inference
ALIYUN_TTS_MODEL=cosyvoice-v3-flash
ALIYUN_TTS_VOICE=longanyang
ALIYUN_TTS_SAMPLE_RATE=24000
